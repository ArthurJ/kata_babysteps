fizzbuzz :: Int => Text
lambda (x)
    both: "FizzBuzz"
    fizz: "Fizz"
    buzz: "Buzz"
    otherwise: str x
    with
        fizz as = 0 (mod x 3)
        buzz as = 0 (mod x 5)
        both as and fizz buzz

fizzbuzz_list :: List::Int => List::Text
lambda (lista)
    lista |> map (fizzbuzz) _

action main
    let nums [1..15]
    let result (fizzbuzz_list nums)
    echo! (str result)

main!