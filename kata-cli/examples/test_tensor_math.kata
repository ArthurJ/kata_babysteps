# Como o compilador Kata entende os Shapes:
# + exige que os tensores tenham o mesmo Shape exato.
# * e dot exigem a regra M x N * N x P = M x P.

action main
    # 1. Tensores 1D Matemáticos (Atenção aos separadores)
    
    # Vetor Linha (1 x 3)
    let v_linha {1 2 3 ;} 
    
    # Vetor Coluna (3 x 1)
    let v_coluna {
        4 ;
        5 ;
        6
    }
    
    # 2. Operação Escalar (Produto Interno/Dot)
    # A regra bate: (1x3) dot (3x1) resulta num escalar!
    let escalar (dot v_linha v_coluna)
    
    # 3. Matrizes Estáticas
    # Matriz 2x3 (Duas linhas, três colunas)
    let m1 {
        1 2 3 ;
        4 5 6
    }
    
    # Matriz 2x3
    let m2 {
        10 10 10 ;
        20 20 20
    }
    
    # 4. Operações Garantidas pelo Type Checker
    # O compilador autoriza porque m1 (2x3) e m2 (2x3) tem o mesmo Shape
    let matriz_soma (+ m1 m2)
    
    echo! "Matematica de Tensores aprovada na compilacao!"

main!