quicksort :: [Int] => [Int]
lambda []: []
lambda [pivo:resto]:
    [quicksort menores : [pivo : quicksort maiores]]
    with
        menores as filter $(< _ pivo) resto
        maiores as filter $(>= _ pivo) resto

action main
    let nums [5 2 9 1 5 6]
    let ordenado $(quicksort nums)
    echo! "Ordenacao Concluida"

main!