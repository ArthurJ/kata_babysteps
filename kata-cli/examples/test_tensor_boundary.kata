# Mock de uma função que lê um banco e retorna um Array dinâmico genérico
ler_banco :: () => Array::Int
lambda : {10 20 30 40}

action processa_ok (tensor_seguro)
    echo! "Sucesso"

action processa_err (motivo)
    echo! "Falhou"

action main
    let dados_dinamicos ler_banco

    # 1. A Coerção de Fronteira (Type Constructor forçando um Shape 2x2)
    # A variável 'tentativa' é do tipo Result::(Tensor::Int::(2 2))::Text
    let tentativa Tensor dados_dinamicos

    echo! "Tratamento delegado para as funcoes acima"

main!