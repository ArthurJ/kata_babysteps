# Teste de patterns aninhados

# Pattern simples (x y) - tupla de 2 elementos
foo :: (Int Int) => Int
lambda (x y):
    + x y

# Pattern aninhado (x (y z)) - tupla onde segundo elemento é outra tupla
bar :: (Int (Int Int)) => Int
lambda (x (y z)):
    + x $(+ y z)

# Pattern cons simples [x:xs]
sum_list :: List::Int => Int
lambda []:
    0
lambda [x:xs]:
    + x sum_list xs

action main
    let a $(foo (1 2))
    let b $(bar (1 (2 3)))
    let c $(sum_list [1 2 3 4 5])
    echo! "foo:" a
    echo! "bar:" b
    echo! "sum_list:" c

main!