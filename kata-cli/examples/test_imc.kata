enum CategoriaIMC
    | Magreza
    | Normal
    | Sobrepeso
    | Obesidade

data Peso as (Float, > _ 0.0)
data Altura as (Float, > _ 0.0)

calcular_imc :: (Peso Altura) => CategoriaIMC
lambda (p a)
    magreza: Magreza
    normal: Normal
    sobrepeso: Sobrepeso
    otherwise: Obesidade
    with
        imc as / p (* a a)
        magreza as < imc 18.5
        normal as < imc 25.0
        sobrepeso as < imc 30.0

action main
    let c (calcular_imc 70.0 1.75)
    echo! "Concluido"

main!